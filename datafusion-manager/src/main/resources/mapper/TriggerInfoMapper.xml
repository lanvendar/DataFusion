<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.datafusion.manager.scheduler.dao.TriggerInfoMapper">

    <select id="getByTriggerId" resultType="com.datafusion.manager.scheduler.po.TriggerInfoEntity">
        select *
        from scheduler_trigger_info
        where id = #{triggerId}
    </select>

</mapper>
