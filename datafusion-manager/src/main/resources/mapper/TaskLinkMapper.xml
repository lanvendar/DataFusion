<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.datafusion.manager.scheduler.dao.TaskLinkMapper">

    <select id="listByFlowId" resultType="com.datafusion.manager.scheduler.po.TaskLinkEntity">
        select *
        from scheduler_task_link
        where flow_id = #{flowId}
    </select>

</mapper>
