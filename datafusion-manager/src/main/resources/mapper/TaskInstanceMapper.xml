<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.datafusion.manager.scheduler.dao.TaskInstanceMapper">

    <select id="getInstanceById" resultType="com.datafusion.manager.scheduler.po.TaskInstanceEntity">
        select *
        from scheduler_task_instance
        where id = #{instanceId}
    </select>

    <select id="listInsIdsByFlowInsId" resultType="java.util.UUID">
        select id
        from scheduler_task_instance
        where flow_instance_id = #{flowInstanceId}
    </select>

    <select id="listByFlowInsId" resultType="com.datafusion.manager.scheduler.po.TaskInstanceEntity">
        select *
        from scheduler_task_instance
        where flow_instance_id = #{flowInstanceId}
        order by create_time asc
    </select>

    <delete id="removeByInstanceId">
        delete from scheduler_task_instance
        where id = #{instanceId}
    </delete>

    <delete id="removeByFlowInsId">
        delete from scheduler_task_instance
        where flow_instance_id = #{flowInstanceId}
    </delete>

</mapper>
