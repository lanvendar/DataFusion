<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.datafusion.manager.asset.dao.TagAccessStatsMapper">

    <select id="selectAll" resultType="com.datafusion.manager.asset.po.TagAccessStatsEntity">
        SELECT id, tag, dimension, uri
        FROM tag_access_stats
        WHERE uri IS NOT NULL
    </select>

</mapper>
