    <select id="listNodeByClassify" resultMap="listNodeByClassifyMap">
        select case
        when node_type = 'DATABASE' then (string_to_array(node_urn, ':'))[1]
        when node_type = 'SERVICE' then node_type
        end as type,
        case
        when node_type = 'DATABASE' then (string_to_array(node_urn, ':'))[2]
        when node_type = 'SERVICE' then (string_to_array(node_urn, ':'))[5]
        end as parentNodeName,
        case
        when node_type = 'DATABASE' then (string_to_array(node_urn, ':'))[5]
        when node_type = 'SERVICE' then (string_to_array(node_urn, ':'))[7]
        end as nodeName,
        node_name as subNodeName,
        node_urn as subNodeUrn
        from asset_lineage_node
        <where>
            <if test="req != null">
                <if test="req.nodeType != null">
                    node_type = #{req.nodeType}
                </if>

                <if test="req.nodeName != null">
                    and node_name = #{req.nodeName}
                </if>
            </if>
        </where>
    </select>-->

    <select id="pageTableColumnsCount" resultType="java.lang.Integer">
        select count(0) from asset_lineage_node
        where node_type = 'DATABASE'
        and node_sub_type = 'TABLE'
        and (string_to_array(node_urn, ':'))[2] = #{req.option.dataSourceName}
        <if test="req.option.nodeName != null">
            and nodeName like concat('%',#{req.option.nodeName},'%')
        </if>
    </select>

    <resultMap id="pageTableColumnsListMap" type="com.datafusion.manager.asset.dto.TableColumnsNodeDto">
        <id column="tableNodeUrn" property="tableNodeUrn"/>
        <result column="tableNodeName" property="tableNodeName"/>
        <collection property="columns" ofType="com.datafusion.manager.asset.dto.ColumnNodeDto">
            <result column="columnNodeName" property="columnNodeName" />
            <result column="columnNodeUrn" property="columnNodeUrn" />
        </collection>
    </resultMap>

    <select id="pageTableColumnsList" resultMap="pageTableColumnsListMap">
        select s.node_urn as tableNodeUrn, s.node_name as tableNodeName, n.node_name as columnNodeName, n.node_urn as columnNodeUrn
        from datafusion.asset_lineage_node n
        join
        (select node_urn, node_name
        from datafusion.asset_lineage_node
        where node_type = 'DATABASE'
        and node_sub_type = 'TABLE'
        and (string_to_array(node_urn, ':'))[2] = #{req.option.dataSourceName}
        <if test="req.option.nodeName != null">
            and nodeName like concat('%',#{req.option.nodeName},'%')
        </if>
        limit #{req.size} offset #{req.offset}) s on n.node_urn like concat(s.node_urn, ':%')
    </select>

    <select id="selectByNodeUrn" resultType="com.datafusion.manager.asset.po.AssetLineageNodeEntity">
        select id, node_urn, node_name, node_type, node_sub_type, node_prop, creator, updater, create_time, update_time
        from asset_lineage_node
        where node_urn = #{nodeUrn}
    </select>

    <select id="selectNodeResourceByNodeUrn" resultType="com.datafusion.manager.asset.dto.AssetLineageNodeResourceDto">
        select
            aln.node_urn,
            aln.node_name,
            aln.node_type,
            aln.node_sub_type,
            aln.node_prop,
            alr.resource_name,
            alr.resource_tag,
            alr.resource_type
        from
            (
                select
                    *
                from
                    datafusion.asset_lineage_node
                where
                        node_urn = #{nodeUrn}) aln
                join datafusion.asset_lineage_node_resource_relation alnrr on
                aln.id = alnrr.node_id
                join datafusion.asset_lineage_resource alr on
                alnrr.resource_id = alr.id
    </select>

    <select id="selectByNodeUrns" resultType="com.datafusion.manager.asset.po.AssetLineageNodeEntity">
        select id, node_urn, node_name, node_type, node_sub_type, node_prop, creator, updater, create_time, update_time
        from asset_lineage_node
        where node_urn in
        <foreach collection="nodeUrns" item="nodeUrn" open="(" separator="," close=")">
            #{nodeUrn}
        </foreach>
    </select>
    <select id="getNodeUrn" resultType="java.lang.String">
        select
            node_urn
        from
            asset_lineage_node
        where
            node_urn like concat('%:',#{datasourceName},':%')
          and node_urn like concat('%:',#{tableNameColumnName})
    </select>

    <delete id="deleteByIds" parameterType="java.util.UUID">
        delete from asset_lineage_node where id in
        <foreach item="id" collection="ids" separator="," close=")" open="(">
            #{id}
        </foreach>
    </delete>

</mapper>