            <result column="nodeUrn" property="nodeUrn"/>

            &lt;!&ndash; 映射 ParentSubNodeVo 的 List<ParentSubNodeVo> subNodes 属性 &ndash;&gt;
            &lt;!&ndash; 这里的 column="subNodeName" 对应SQL中的 subNodeName 别名 &ndash;&gt;
            &lt;!&ndash; 同样需要一个 unique ID 来区分 subNodes &ndash;&gt;
            <collection property="subNodes" ofType="com.datafusion.manager.asset.dto.ParentSubNodeVo">
                <id column="subNodeName" property="nodeName"/> &lt;!&ndash; subNodeName 是子节点的 nodeName &ndash;&gt;
                <result column="subNodeUrn" property="nodeUrn"/> &lt;!&ndash; subNodeUrn 是子节点的 nodeUrn &ndash;&gt;
            </collection>
        </collection>
