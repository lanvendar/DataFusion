            &lt;!&ndash; 如果subNodes还有更下一层，需要继续在这里嵌套 collection，并提供更深层级的 unique ID &ndash;&gt;
        </collection>
    </resultMap>-->


    <!--<resultMap id="listNodeByClassifyMap" type="com.datafusion.manager.asset.dto.NodeClassifyVo">
        &lt;!&ndash; NodeClassifyVo 的基本属性 &ndash;&gt;
        &lt;!&ndash; type 和 parentNodeName 需要能唯一标识一个 NodeClassifyVo 实例 &ndash;&gt;
        <id column="type" property="type"/> &lt;!&ndash; 假设 type 是最顶层的分组依据之一 &ndash;&gt;
        <id column="parentNodeName" property="parentNodeName"/> &lt;!&ndash; 假设 type + parentNodeName 可以唯一标识一个分组 &ndash;&gt;

        &lt;!&ndash; 映射 NodeClassifyVo 的 List<ParentSubNodeVo> nodes 属性 &ndash;&gt;
        <collection property="nodes" ofType="com.datafusion.manager.asset.dto.ParentSubNodeVo">
            &lt;!&ndash; 这里的 column="nodeName" 对应SQL中的 nodeName 别名 &ndash;&gt;
            &lt;!&ndash; id 标签用于唯一标识 ParentSubNodeVo 对象，MyBatis会根据这个ID去重 &ndash;&gt;
