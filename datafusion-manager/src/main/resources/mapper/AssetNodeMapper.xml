<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.datafusion.manager.asset.dao.AssetLineageNodeMapper">

    <!--<resultMap id="parentSubNodeVoMap" type="com.datafusion.manager.asset.dto.ParentSubNodeVo">
