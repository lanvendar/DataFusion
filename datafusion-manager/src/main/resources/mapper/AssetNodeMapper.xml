        <id column="nodeName" property="nodeName" javaType="java.lang.String"/>
        <result column="nodeUrn" property="nodeUrn"/>

        &lt;!&ndash; 递归映射子节点 &ndash;&gt;
        &lt;!&ndash; 这里的 subNodes 对应 ParentSubNodeVo 类中的 List<ParentSubNodeVo> subNodes 属性 &ndash;&gt;
        &lt;!&ndash; 注意：此处的 collection 应该映射到 ParentSubNodeVo 的 subNodes 属性 &ndash;&gt;
