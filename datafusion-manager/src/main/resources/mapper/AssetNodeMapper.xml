        <collection property="subNodes" ofType="com.datafusion.manager.asset.dto.ParentSubNodeVo">
            &lt;!&ndash; 子节点的ID和属性，确保这些列在SQL中被查询出来，并且与上层节点的ID不冲突 &ndash;&gt;
            <id column="subNodeName" property="nodeName"/> &lt;!&ndash; 使用 subNodeName 作为子节点的 nodeName &ndash;&gt;
