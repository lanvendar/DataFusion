        "loadMode": "UPSERT",
        "options": {
          "bucket": "1",
          "write-buffer-size": "128mb",
          "file.format": "parquet"
        },
        "columnsMapping": "data"
      },
      {
        "enabled": true,
        "table": {
          "database": "dw_dev",
          "name": "ods_spider_bkccpr_central_parity_rate",
          "comment": "人民币汇率中间价表",
          "createIfNotExists": true,
          "includeKafkaMetadataFields": false,
          "partitionKeys": [
            "day_pt"
