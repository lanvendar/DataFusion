{
  "job": {
    "id": "kafka_json_ods_spider_oilchem_price_market",
    "name": "Kafka JSON Ods Spider OilChem Price Market To Paimon",
    "version": "1.0.0"
  },
  "source": {
    "type": "KAFKA",
    "bootstrapServers": "sz-kafka.indusmind.me:9094",
    "topics": [
      "dw-web-spider-paimon-test"
