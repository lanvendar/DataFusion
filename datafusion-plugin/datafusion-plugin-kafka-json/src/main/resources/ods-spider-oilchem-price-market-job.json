              "varieties_id",
              "category_name",
              "sub_category_name",
              "business_type",
              "two_level_business_type",
              "region_id",
              "internal_market_name",
              "sale_region_name",
              "standard",
              "brand_name",
              "specifications_name",
              "purpose_name",
              "process",
              "producer",
              "price_type_name",
              "receiving_station"
            ]
          }
        },
        "loadMode": "UPSERT",
        "options": {
          "bucket": "4",
          "write-buffer-size": "128mb",
          "file.format": "parquet"
        },
        "columnsMapping": "data"
      },
      {
        "enabled": true,
        "table": {
          "database": "dw_dev",
          "name": "ods_spider_cci_thermal_coal_price",
          "comment": "CCI秦皇岛港动力煤价格指标表",
