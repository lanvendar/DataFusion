      "database": "dw_prod",
      "s3.endpoint": "http://sz-s3.indusmind.me",
      "s3.endpoint.region": "us-east-1",
      "s3.access-key": "DNFY3F8DZ102RKOAXIMJ",
      "s3.secret-key": "PWJhEKozJxXzIxbdpJs5lZUxuhklk43pDvFX7IVu",
      "s3.path.style.access": "true",
      "s3.connection.ssl.enabled": "false",
      "s3.fast.upload.buffer": "array",
      "bucket": "2",
      "write-buffer-size": "128mb",
      "file.format": "parquet"
    },
    "tables": [
      {
        "enabled": true,
        "table": {
          "database": "dw_dev",
          "name": "ods_spider_oilchem_price_market",
