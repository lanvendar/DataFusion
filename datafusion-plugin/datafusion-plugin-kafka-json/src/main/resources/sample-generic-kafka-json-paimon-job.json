{
  "job": {
    "id": "sample_generic_kafka_json_paimon",
    "name": "Sample Generic Kafka JSON To Paimon",
    "version": "1.0.0"
  },
  "source": {
    "type": "KAFKA",
    "bootstrapServers": "kafka-1:9092,kafka-2:9092",
    "topics": [
      "generic-kafka-json-topic"
    ],
    "groupId": "datafusion-plugin-kafka-json-generic",
    "startingOffsets": "group-offsets",
    "properties": {}
  },
  "runtime": {
    "parallelism": 2,
    "deploymentMode": "LOCAL",
    "executionMode": "STREAMING",
    "checkpointMode": "AT_LEAST_ONCE",
    "checkpointIntervalMs": 60000,
    "checkpointTimeoutMs": 600000,
    "maxConcurrentCheckpoints": 1,
    "checkpointStorage": "file:///tmp/flink-checkpoints/kafka-json-generic-paimon",
    "stateBackend": "HASHMAP",
    "restartStrategy": "FIXED_DELAY",
    "restartAttempts": 3,
    "restartDelayMs": 10000
  },
  "sink": {
    "type": "PAIMON",
    "connectType": "S3",
    "schemaMismatchPolicy": "SKIP",
    "recordErrorPolicy": "SKIP",
    "loadMode": "UPSERT",
    "options": {
      "warehouse": "s3://data-lake-warehouse/paimon",
      "catalogType": "filesystem",
      "database": "dw_prod",
      "s3.endpoint": "http://s3.example.com",
      "s3.endpoint.region": "us-east-1",
      "s3.access-key": "${env:PAIMON_S3_ACCESS_KEY}",
      "s3.secret-key": "${env:PAIMON_S3_SECRET_KEY}",
      "s3.path.style.access": "true",
      "s3.connection.ssl.enabled": "false",
      "s3.fast.upload.buffer": "array",
      "bucket": "2",
      "write-buffer-size": "128mb",
      "file.format": "parquet"
    },
    "tables": [
      {
        "enabled": true,
        "table": {
          "database": "dw_dev",
          "name": "ods_generic_event",
          "comment": "通用 Kafka JSON 样例表",
          "createIfNotExists": true,
          "partitionKeys": [
            "day_pt"
          ],
          "primaryKeys": {
            "mode": "PROXY",
            "defaultValue": [
              "day_pt",
              "event_id"
            ]
          }
        },
        "columnsMapping": "payload.items",
        "loadMode": "UPSERT",
        "columns": [
          {
            "name": "event_id",
            "dataType": "VARCHAR",
            "length": 64,
            "nullable": false,
            "comment": "事件 ID",
            "value": {
              "path": "id",
              "defaultValue": "_UNKNOWN_"
            }
          },
          {
            "name": "event_name",
            "dataType": "VARCHAR",
            "length": 128,
            "nullable": true,
            "comment": "事件名称",
            "value": {
              "path": "name"
            }
          },
          {
            "name": "event_amount",
            "dataType": "DECIMAL",
            "precision": 18,
            "scale": 4,
            "nullable": true,
            "comment": "事件金额",
            "value": {
              "path": "metrics.amount"
            }
          },
          {
            "name": "day_pt",
            "dataType": "DATE",
            "nullable": false,
            "comment": "分区日期",
            "format": "yyyy-MM-dd",
            "value": {
              "path": "event_date",
              "defaultValue": "1970-01-01"
            }
          }
        ],
        "options": {
          "bucket": "4",
          "write-buffer-size": "128mb",
          "file.format": "parquet"
        }
      }
    ],
    "writer": {
      "batchSize": 1000,
      "flushIntervalMs": 5000,
      "maxOpenWriters": 256
    }
  }
}
